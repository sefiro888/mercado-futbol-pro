# ============================================================================
# Variables de entorno de EJEMPLO. Copia este archivo a `.env.local`.
#
# IMPORTANTE: en una app de frontend (Vite), TODA variable con prefijo VITE_
# queda expuesta en el navegador. NUNCA pongas aquí claves secretas de APIs de
# pago ni el "service_role" de Supabase. Esas claves deben vivir en el backend
# o en funciones serverless (ver ROADMAP_AUTOMATIZACION.md).
# ============================================================================

# Origen de datos: "local" (JSON de demo) | "supabase" | "api"
VITE_DATA_SOURCE=local

# Solo claves PÚBLICAS / anónimas (seguras para el cliente):
# VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
# VITE_SUPABASE_ANON_KEY=clave-anonima-publica

# ----------------------------------------------------------------------------
# SOLO para el script de carga local (npm run seed). NO llevan prefijo VITE_,
# así que NUNCA se exponen en el navegador. La service_role es SECRETA: úsala
# solo en tu máquina y no la subas a git (.env.local ya está en .gitignore).
# ----------------------------------------------------------------------------
# SUPABASE_URL=https://tu-proyecto.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=clave-secreta-service-role
